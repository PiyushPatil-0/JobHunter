# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
# Covers both naming conventions (this project currently uses .venv,
# not venv - .venv was previously NOT covered by this file).
.venv/
venv/
env/
ENV/

# --- Secrets ---
.env
.env.*
!.env.example

# --- Database ---
*.db
*.sqlite
*.sqlite3
data/

# --- Logs ---
logs/
*.log

# --- Resume / personal uploads ---
# Runtime-uploaded resumes are personal data and must never be
# committed, even accidentally.
resume/*
!resume/.gitkeep

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
playwright-report/
test-results/

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Agent/scratch dirs (project-specific; remove if not applicable) ---
.agents/